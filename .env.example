POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Proxy Vite vers le backend. Avec docker compose dev : http://backend:5000
# En local sans Docker : http://127.0.0.1:5002 (ou le port exposé du back)
VITE_DEV_PROXY_TARGET=http://backend:5000
# Temps expiration token
EXPIRE_TIME_MINUTE=2
DB_HOST=postgres
DB_NAME=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
MAIL_FETCH_INTERVAL_MINUTES=2
LOG_DIR=/var/log/flowrank
# Google OAuth (flow liaison compte ; redirect_uri = Origin de la requête + /auth/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SECRET_KEY=dev-only-change-in-production-use-a-long-random-string
ALGORITHM=HS256
APP_URL=http://localhost:5173/

# Tri IA (FlowRank/mailSort sur le Hub)
HF_HOME=/var/cache/huggingface
MAIL_SORT_MODEL_ID=FlowRank/mailSort
MAIL_SORT_INTERVAL_MINUTES=10
MAIL_SORT_BATCH_SIZE=9499 # Limite correspondante au nombre d'emails dans notre dataset
MAIL_SORTER_CLASS_PATH=back.workflows.mail_sorting.hf_text_classifier.HfTextClassificationSorter

# Seed dev (déconseillé en prod)
DEV_SEED_EMAIL=dev@flowrank.local
DEV_SEED_PASSWORD=dev

# Destinataire fictif des mails importés depuis le Hub (défaut: DEV_SEED_EMAIL)
LABELED_EMAILS_RECEIVER_EMAIL=