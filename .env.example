POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Proxy Vite vers le backend. Avec docker compose dev : http://backend:5000
# En local sans Docker : http://127.0.0.1:5002 (ou le port exposé du back)
VITE_DEV_PROXY_TARGET=http://backend:5000
# Temps expiration token
EXPIRE_TIME_MINUTE=2
DB_HOST=postgres
DB_NAME=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me

# Google OAuth (flow liaison compte)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL de callback frontend (ex: http://localhost:5173/auth/callback en dev)
GOOGLE_REDIRECT_URI=